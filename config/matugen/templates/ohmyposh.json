{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": "/home/abraham/.config/ohmyposh/colors.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:color15",
          "template": "\n╭─"
        },
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": "",
          "foreground": "p:color15",
          "background": "p:color13",
          "template": "{{ .UserName }}"
        },
        {
          "type": "os",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:color15",
          "background": "p:color13",
          "template": "{{ .Icon }}  "
        },
        {
          "type": "path",
          "style": "diamond",
          "trailing_diamond": "",
          "foreground": "p:color13",
          "background": "p:color10",
          "template": " 󰉖 {{ path .Path .Location }}",
          "properties": { "style": "full" }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:color15",
          "template": "╰─ ❯❯",
          "properties": { "always_enabled": true }
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "final_space": true
}
